<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sau.med.controller.AppointmentController"
            prefHeight="230.0" prefWidth="450.0">
    <children>
        <Label layoutX="24.0" layoutY="20.0" text="APP ID:"/>
        <Label layoutX="24.0" layoutY="52.0" text="PATIENT ID:"/>
        <Label layoutX="24.0" layoutY="84.0" text="DOCTOR ID:"/>
        <Label layoutX="24.0" layoutY="116.0" text="APP DATE:"/>
        <Label layoutX="24.0" layoutY="148.0" text="APP TIME:"/>

        <TextField fx:id="appointmentId" layoutX="122.0" layoutY="16.0" prefWidth="168.0"/>
        <TextField fx:id="patientId" layoutX="122.0" layoutY="48.0" prefWidth="168.0"/>
        <TextField fx:id="doctorId" layoutX="122.0" layoutY="80.0" prefWidth="168.0"/>
        <TextField fx:id="appointmentDate" layoutX="122.0" layoutY="112.0" prefWidth="168.0" promptText="YYYY-MM-DD"/>
        <TextField fx:id="appointmentTime" layoutX="122.0" layoutY="144.0" prefWidth="168.0" promptText="HH:MM:SS"/>

        <Button fx:id="getAppointment" layoutX="310.0" layoutY="16.0" mnemonicParsing="false" onAction="#getAppointment" text="GET"/>
        <Button fx:id="clearAppointment" layoutX="310.0" layoutY="80.0" mnemonicParsing="false" onAction="#clearAppointment" text="CLEAR"/>

        <Button fx:id="saveAppointment" layoutX="34.0" layoutY="188.0" mnemonicParsing="false" onAction="#saveAppointment" text="SAVE"/>
        <Button fx:id="updateAppointment" layoutX="104.0" layoutY="188.0" mnemonicParsing="false" onAction="#updateAppointment" text="UPDATE"/>
        <Button fx:id="deleteAppointment" layoutX="188.0" layoutY="188.0" mnemonicParsing="false" onAction="#deleteAppointment" text="DELETE"/>
        <Button fx:id="close" layoutX="272.0" layoutY="188.0" mnemonicParsing="false" onAction="#close" text="CLOSE"/>
    </children>
</AnchorPane>
