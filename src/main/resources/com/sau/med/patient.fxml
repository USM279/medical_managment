<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sau.med.controller.PatientController"
            prefHeight="230.0" prefWidth="450.0">
    <children>
        <Label layoutX="24.0" layoutY="24.0" text="ID:"/>
        <Label layoutX="24.0" layoutY="57.0" text="NAME:"/>
        <Label layoutX="24.0" layoutY="90.0" text="ADDRESS:"/>
        <Label layoutX="24.0" layoutY="123.0" text="TELEPHONE:"/>

        <TextField fx:id="patientId" layoutX="110.0" layoutY="20.0" prefWidth="180.0"/>
        <TextField fx:id="name" layoutX="110.0" layoutY="53.0" prefWidth="180.0"/>
        <TextField fx:id="address" layoutX="110.0" layoutY="86.0" prefWidth="180.0"/>
        <TextField fx:id="telephone" layoutX="110.0" layoutY="119.0" prefWidth="180.0"/>

        <Button fx:id="getPatient" layoutX="310.0" layoutY="20.0" mnemonicParsing="false" onAction="#getPatient" text="GET"/>
        <Button fx:id="clearPatient" layoutX="310.0" layoutY="86.0" mnemonicParsing="false" onAction="#clearPatient" text="CLEAR"/>

        <Button fx:id="savePatient" layoutX="34.0" layoutY="178.0" mnemonicParsing="false" onAction="#savePatient" text="SAVE"/>
        <Button fx:id="updatePatient" layoutX="104.0" layoutY="178.0" mnemonicParsing="false" onAction="#updatePatient" text="UPDATE"/>
        <Button fx:id="deletePatient" layoutX="188.0" layoutY="178.0" mnemonicParsing="false" onAction="#deletePatient" text="DELETE"/>
        <Button fx:id="close" layoutX="272.0" layoutY="178.0" mnemonicParsing="false" onAction="#close" text="CLOSE"/>
    </children>
</AnchorPane>
